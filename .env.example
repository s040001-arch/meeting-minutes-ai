# Copy this file to ".env" in the project root and fill in values.
# Used at startup by drive_auto_run_forever, drive_auto_run_once, run_job_once.
# Existing environment variables are never overwritten.

# ── AI APIs ──────────────────────────────────────
# Anthropic (Claude 3.5 Sonnet) — used by Step 4.3 AI correction
ANTHROPIC_API_KEY=

# OpenAI — used by review_risky_terms, run_question_cycle_once, generate_minutes
OPENAI_API_KEY=

# ── LINE Messaging API ───────────────────────────
LINE_CHANNEL_ACCESS_TOKEN=
LINE_USER_ID=

# ── Google Drive ─────────────────────────────────
# Folder ID to monitor for new audio files
DRIVE_FOLDER_ID=

# Polling interval in seconds (default: 120)
# DRIVE_POLL_INTERVAL_SEC=120

# ── Google OAuth (Railway only) ──────────────────
# Paste the full JSON content of each file.
# railway_bootstrap.py writes them to disk at startup.
# GOOGLE_OAUTH_CLIENT_JSON=
# GOOGLE_OAUTH_TOKEN_DRIVE_JSON=
# GOOGLE_OAUTH_TOKEN_JSON=
