# Copy this file to ".env" in the project root and fill in values.
# Used at startup by drive_auto_run_forever, drive_auto_run_once, run_job_once.
# Existing environment variables are never overwritten.

# LINE Messaging API (Messaging API channel → Channel access token)
LINE_CHANNEL_ACCESS_TOKEN=

# Your LINE user ID (recipient of push messages)
LINE_USER_ID=

# Optional: Railway 等で Webhook だけ動かすとき、質問 push 後に remote_pending を同期する
# LINE_PENDING_SYNC_URL=https://YOUR_HOST.up.railway.app/line/pending
# LINE_PENDING_SYNC_SECRET=shared_secret_with_Railway_env
